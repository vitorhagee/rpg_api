{
  "compilerOptions": {
    "target": "ES2020",

    "module": "ESNext",
    "moduleResolution": "bundler",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "types": ["node"]
  },

  "include": ["src", "prisma.config.ts"],

  "exclude": ["node_modules"]
}
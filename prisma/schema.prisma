generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Item {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  weight      Int
  rarity      String
  price       Int
  quantity    Int
  description String
  createAt    DateTime @default(now())
}